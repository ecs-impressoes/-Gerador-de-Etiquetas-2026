
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Pibbaweb - Gerador de Etiquetas 2026</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<style>
:root{
  --blue-dark:#0d2a4d;
  --blue-mid:#1f4e79;
  --blue-light:#eaf2fb;
}

body{
  margin:0;
  font-family:Arial, Helvetica, sans-serif;
  background:#f4f6f8;
}

/* HEADER */
header{
  position:sticky;
  top:0;
  z-index:1000;
  background:linear-gradient(90deg,var(--blue-dark),var(--blue-mid));
  color:#fff;
  padding:15px 20px;
}

.header-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.socials{
  display:flex;
  gap:14px;
}

.socials a{
  display:flex;
  align-items:center;
  justify-content:center;
  width:34px;
  height:34px;
  border-radius:50%;
  background:rgba(255,255,255,0.15);
  transition:background .3s;
}

.socials a:hover{
  background:rgba(255,255,255,0.3);
}

.socials svg{
  width:18px;
  height:18px;
  fill:#fff;
}

main{padding:20px}

.container{
  display:flex;
  gap:20px;
}

.controls{
  width:360px;
  background:#fff;
  padding:20px;
  border-radius:8px;
}

.controls label{
  margin-top:12px;
  display:block;
  font-weight:bold;
  color:var(--blue-dark);
}

.controls input,
.controls select{
  width:100%;
  padding:7px;
  margin-top:4px;
}

.controls button{
  margin-top:15px;
  width:100%;
  padding:10px;
  background:var(--blue-mid);
  color:#fff;
  border:none;
  cursor:pointer;
}

.preview{
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:25px;
}

.a4{
  width:210mm;
  height:297mm;
  background:#fff;
  position:relative;
  box-shadow:0 0 10px rgba(0,0,0,.3);
}

.sheet{
  position:absolute;
  top:10mm;
  left:10mm;
  right:10mm;
  bottom:22mm;
  display:grid;
  gap:1.5mm;
  justify-content:center;
  align-content:center;
}

.label{
  border-radius:50%;
  overflow:hidden;
  position:relative;
}

.label img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.guide{
  position:absolute;
  width:100%;
  height:100%;
  border:0.5mm dashed #aaa;
  border-radius:50%;
  pointer-events:none;
}

.footer{
  position:absolute;
  bottom:6mm;
  left:10mm;
  width:190mm;
  font-size:9px;
  text-align:center;
}
</style>
</head>

<body>

<header>
  <div class="header-top">
    <h2>Pibbaweb - Gerador de Etiquetas 2026</h2>

    <div class="socials">
      <a href="https://www.instagram.com/pibbaweb1/" target="_blank" title="Instagram">
        <svg viewBox="0 0 24 24"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm6.5-.9a1.1 1.1 0 1 0 0 2.2 1.1 1.1 0 0 0 0-2.2z"/></svg>
      </a>
      <a href="https://www.youtube.com/user/pibbaweb" target="_blank" title="YouTube">
        <svg viewBox="0 0 24 24"><path d="M23 7.5s-.2-1.7-.8-2.4c-.8-.8-1.7-.8-2.1-.9C16.9 4 12 4 12 4s-4.9 0-8.1.2c-.4.1-1.3.1-2.1.9C1.2 5.8 1 7.5 1 7.5S.8 9.4.8 11.2v1.6c0 1.8.2 3.7.2 3.7s.2 1.7.8 2.4c.8.8 1.9.8 2.4.9 1.7.2 7.8.2 7.8.2s4.9 0 8.1-.2c.4-.1 1.3-.1 2.1-.9.6-.7.8-2.4.8-2.4s.2-1.9.2-3.7v-1.6c0-1.8-.2-3.7-.2-3.7zM9.7 14.6V7.8l6.2 3.4-6.2 3.4z"/></svg>
      </a>
      <a href="https://www.facebook.com/pibbaweb1" target="_blank" title="Facebook">
        <svg viewBox="0 0 24 24"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H8v-2.9h2.4V9.8c0-2.4 1.4-3.7 3.6-3.7 1 0 2 .2 2 .2v2.3h-1.1c-1.1 0-1.4.7-1.4 1.4v1.7H16l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/></svg>
      </a>
      <a href="https://wa.me/5513988089754" target="_blank" title="WhatsApp">
        <svg viewBox="0 0 24 24"><path d="M20 3.9A11.8 11.8 0 0 0 3.2 18.7L2 22l3.4-1.1A11.8 11.8 0 1 0 20 3.9zm-8.2 16a9.6 9.6 0 0 1-4.9-1.4l-.3-.2-2.9.9.9-2.8-.2-.3a9.6 9.6 0 1 1 7.4 3.8zm5.3-7.2c-.3-.1-1.8-.9-2.1-1s-.5-.1-.7.1-.8 1-.9 1.2-.3.2-.6.1a7.9 7.9 0 0 1-2.3-1.4 8.5 8.5 0 0 1-1.6-2c-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.2.1-.3.2-.5.1-.2 0-.4 0-.5s-.7-1.7-1-2.3c-.3-.6-.6-.5-.7-.5h-.6c-.2 0-.5.1-.7.3s-.9.9-.9 2.1.9 2.4 1 2.5c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.6.6.2 1.2.2 1.6.1.5-.1 1.8-.7 2-1.4.2-.7.2-1.3.1-1.4s-.2-.2-.5-.3z"/></svg>
      </a>
    </div>
  </div>
</header>

<main>
<div class="container">

<div class="controls">
<label>Tamanho da Etiqueta (mm)</label>
<select id="size">
<option>25</option><option>30</option><option>35</option><option>40</option>
<option>45</option><option>50</option><option>60</option><option>70</option>
<option>80</option><option>90</option><option>100</option>
<option>120</option><option>150</option>
</select>

<label>Tipo de Impressão</label>
<select id="mode">
<option value="front">Só Frente</option>
<option value="both">Frente e Verso</option>
</select>

<label>Arquivo Frente</label>
<input type="file" id="front" accept="image/*">

<label id="backLabel" style="display:none">Arquivo Verso</label>
<input type="file" id="back" accept="image/*" style="display:none">

<label>Ajuste de Corte Frente (mm)</label>
<input type="number" id="offsetFront" value="0">

<label>Ajuste de Corte Verso (mm)</label>
<input type="number" id="offsetBack" value="0">

<button onclick="render()">Gerar Layout</button>
<button onclick="exportPDF()">Exportar PDF A4</button>
</div>

<div class="preview" id="preview"></div>

</div>
</main>

<script>
const preview=document.getElementById('preview');
const gap=1.5;

mode.onchange=()=>{
  back.style.display=backLabel.style.display=mode.value==='both'?'block':'none';
};

function loadImg(input){
  return new Promise(r=>{
    const f=new FileReader();
    f.onload=e=>r(e.target.result);
    f.readAsDataURL(input.files[0]);
  });
}

function buildPage(img,offset,guide){
  const base=+size.value;
  const final=base+offset*2;
  const cols=Math.floor((190+gap)/(final+gap));
  const rows=Math.floor((257+gap)/(final+gap));

  const page=document.createElement('div');
  page.className='a4';

  const sheet=document.createElement('div');
  sheet.className='sheet';
  sheet.style.gridTemplateColumns=`repeat(${cols},${final}mm)`;

  for(let i=0;i<cols*rows;i++){
    const l=document.createElement('div');
    l.className='label';
    l.style.width=l.style.height=final+'mm';

    const im=document.createElement('img');
    im.src=img;
    l.appendChild(im);

    if(guide){
      const g=document.createElement('div');
      g.className='guide';
      l.appendChild(g);
    }

    sheet.appendChild(l);
  }

  const footer=document.createElement('div');
  footer.className='footer';
  footer.innerHTML=`Instagram | YouTube | Facebook | WhatsApp | PIX: 13988089754`;

  page.append(sheet,footer);
  return page;
}

async function render(){
  preview.innerHTML='';
  const f=await loadImg(front);
  preview.appendChild(buildPage(f,+offsetFront.value,true));
  if(mode.value==='both'){
    const b=await loadImg(back);
    preview.appendChild(buildPage(b,+offsetBack.value,false));
  }
}

function exportPDF(){
  const {jsPDF}=window.jspdf;
  const pdf=new jsPDF('p','mm','a4');
  const pages=document.querySelectorAll('.a4');
  let i=0;

  pages.forEach(p=>{
    html2canvas(p,{scale:3}).then(c=>{
      if(i>0)pdf.addPage();
      pdf.addImage(c.toDataURL('image/png'),'PNG',0,0,210,297);
      i++;
      if(i===pages.length)pdf.save('Pibbaweb-Etiquetas-2026.pdf');
    });
  });
}
</script>

</body>
</html>
